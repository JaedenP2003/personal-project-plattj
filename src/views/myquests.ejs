<%- include('partials/header') %>

<main>
    <div id="myquests-page">
        <h1 class="section-title">My Quests</h1>
        <div class="divider"></div>

        <% if (!assignments.length) { %>
            <p class="empty-state">You haven't accepted any quests yet. <a href="/quests">Browse available quests</a>.</p>
        <% } else { %>
            <section class="quest-grid">
                <% assignments.forEach(function(assignment) { %>
                    <article class="quest-card">
                        <h3><%= assignment.title %></h3>
                        <p><strong>Category:</strong> <%= assignment.category %></p>
                        <p><strong>Difficulty:</strong> <%= assignment.difficulty %></p>
                        <p><%= assignment.description %></p>
                        <p><strong>Reward:</strong> <%= assignment.reward %></p>
                        <span class="quest-status quest-status-<%= assignment.status.toLowerCase() %>"><%= assignment.status %></span>

                        <%# Accepted: no report yet, show the submit form.
                            Submitted: waiting on a Guild Officer.
                            Completed/Rejected: terminal, show the officer's
                            notes if they left any (no resubmission). %>
                        <% if (assignment.status === 'Accepted') { %>
                            <form class="submission-form" action="/myquests/<%= assignment.assignment_id %>/submit" method="post">
                                <label for="submission_text-<%= assignment.assignment_id %>">Completion Report</label>
                                <textarea id="submission_text-<%= assignment.assignment_id %>" name="submission_text" rows="3" required></textarea>
                                <button type="submit" class="btn btn-small">Submit Report</button>
                            </form>
                        <% } else if (assignment.status === 'Submitted') { %>
                            <p class="submission-note">Your report is in — awaiting review.</p>
                        <% } else if (assignment.review_notes) { %>
                            <p class="submission-note"><strong>Officer notes:</strong> <%= assignment.review_notes %></p>
                        <% } %>

                        <%# Only a Completed quest can be reviewed. If the Hero
                            already left one, show it with edit/delete instead
                            of a second create form (one review per quest). %>
                        <% if (assignment.status === 'Completed') { %>
                            <% if (assignment.review_id) { %>
                                <form class="review-form" action="/reviews/<%= assignment.review_id %>/edit" method="post">
                                    <label for="rating-<%= assignment.review_id %>">Your Rating</label>
                                    <select id="rating-<%= assignment.review_id %>" name="rating">
                                        <% for (let star = 1; star <= 5; star++) { %>
                                            <option value="<%= star %>" <%= assignment.review_rating === star ? 'selected' : '' %>><%= star %> ★</option>
                                        <% } %>
                                    </select>
                                    <label for="comment-<%= assignment.review_id %>">Your Review</label>
                                    <textarea id="comment-<%= assignment.review_id %>" name="comment" rows="2"><%= assignment.review_comment || '' %></textarea>
                                    <div class="review-form-actions">
                                        <button type="submit" class="btn btn-small">Update Review</button>
                                        <button type="submit" form="delete-review-<%= assignment.review_id %>" class="btn btn-small btn-danger">Delete Review</button>
                                    </div>
                                </form>
                                <form id="delete-review-<%= assignment.review_id %>" action="/reviews/<%= assignment.review_id %>/delete" method="post" onsubmit="return confirm('Delete your review for this quest?');"></form>
                            <% } else { %>
                                <form class="review-form" action="/myquests/<%= assignment.assignment_id %>/review" method="post">
                                    <label for="rating-<%= assignment.assignment_id %>">Rate this Quest</label>
                                    <select id="rating-<%= assignment.assignment_id %>" name="rating">
                                        <% for (let star = 5; star >= 1; star--) { %>
                                            <option value="<%= star %>"><%= star %> ★</option>
                                        <% } %>
                                    </select>
                                    <label for="comment-<%= assignment.assignment_id %>">Leave a Review (optional)</label>
                                    <textarea id="comment-<%= assignment.assignment_id %>" name="comment" rows="2"></textarea>
                                    <button type="submit" class="btn btn-small">Post Review</button>
                                </form>
                            <% } %>
                        <% } %>
                    </article>
                <% }) %>
            </section>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>
