<%- include('../partials/header') %>

<%# Rendered by the catch-all 404 handler in server.js for any URL that
    doesn't match a route. %>
<main>
    <div class="error-page">
        <img src="/images/errors/404.svg" alt="A broken signpost deep in the Lost Woods" class="error-image">
        <h1>404</h1>
        <h2>Lost in the Lost Woods</h2>
        <p>This path leads nowhere, traveler. The quest you're looking for doesn't exist.</p>
        <a href="/" class="btn">Return to the Quest Board</a>
    </div>
</main>

<%- include('../partials/footer') %>
