<%- include('partials/header') %>

<main>
    <div class="hero">
        <section id="hero-box">
            <img src="/images/home/hyrulemap.webp" alt="Hyrule Quest Board" class="hero-image">
        </section>
        <section id="hero-msg">
            <h1>Welcome to the Hyrule Quest Board</h1>
            <h2>"Adventure Awaits in Hyrule"</h2>
            <p>Embark on a journey through the land of Hyrule and take on exciting quests!</p>
            <a href="/quests" class="btn">Explore Quests</a>
        </section>
    </div>
    <div id="quests">
        <h2 class="section-title">Featured Quests</h2>
        <div class="divider"></div>
        <% if (!quests.length) { %>
            <p class="empty-state">No quests are posted right now. Check back soon, traveler.</p>
        <% } else { %>
            <section class="quest-grid">
                <% quests.forEach(function(quest) { %>
                    <article class="quest-card">
                        <h3><%= quest.title %></h3>
                        <p><strong>Category:</strong> <%= quest.category %></p>
                        <p><strong>Difficulty:</strong> <%= quest.difficulty %></p>
                        <p><%= quest.description %></p>
                        <p><strong>Reward:</strong> <%= quest.reward %></p>
                        <a href="/quests" class="btn">View Quest</a>
                    </article>
                <% }) %>
            </section>
        <% } %>
    </div>
</main>

<%- include('partials/footer') %>