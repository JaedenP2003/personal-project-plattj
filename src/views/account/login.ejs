<%- include('../partials/header') %>

<%# Same pattern as register.ejs: this is just markup. A wrong email/password
    redirects back here with a generic "Invalid email or password" flash —
    the form never reveals which of the two fields was wrong. %>
<main>
    <div class="form-container">
        <h1>Welcome Back, Hero</h1>

        <form action="/login" method="post">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>

            <label for="password">Password</label>
            <input type="password" id="password" name="password" required>

            <button type="submit" class="btn">Login</button>
        </form>

        <p>Need an account? <a href="/register">Register</a></p>
    </div>
</main>

<%- include('../partials/footer') %>
